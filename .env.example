# GitHub OAuth
# Create a GitHub OAuth App at https://github.com/settings/developers
# Set callback URL to: http://localhost:3000/api/callback
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# MongoDB
# Get your connection string from MongoDB Atlas or use local MongoDB
MONGODB_URI=mongodb://localhost:27017/Commitify

# Encryption
# Generate a secure random string for encrypting tokens
# You can use: openssl rand -hex 32
ENCRYPTION_KEY=your_secure_encryption_key

# CHANGE IT
REDIRECT_URI=http://localhost:3000/api/callback